generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Watering {
  LOW
  MEDIUM
  HIGH
}

enum Light {
  LOW
  MEDIUM
  HIGH
  FULL_SUN
}

enum PlantHeight {
  SMALL
  MEDIUM
  LARGE
}

enum PlantPosition {
  INDOOR
  OUTDOOR
  BOTH
}

enum Difficulty {
  EASY
  MEDIUM
  HARD
}

enum UserRole {
  USER
  ADMIN
  EDITOR
}

enum ListingType {
  PLANT
  CUTTING
  LEAF
  SEEDS
}

enum DeliveryMode {
  PICKUP
  SHIPPING
  BOTH
}

enum ListingStatus {
  PENDING
  ACTIVE
  HIDDEN
  DELETED
  REJECTED
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  name         String?
  role         UserRole  @default(USER)

  listings     Listing[]
  sessions     Session[]
  favorites    Favorite[]
}

model Listing {
  id           String        @id @default(cuid())
  userId       String
  title        String
  description  String
  city         String
  type         ListingType
  deliveryMode DeliveryMode
  status       ListingStatus @default(PENDING)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  watering     Watering?
  light        Light?
  height       PlantHeight?
  position     PlantPosition?
  difficulty   Difficulty?
  petFriendly  Boolean?

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  images       ListingImage[]
  favorites    Favorite[]
}

model ListingImage {
  id        String   @id @default(cuid())
  listingId String
  url       String
  order     Int      @default(0)

  listing   Listing  @relation(fields: [listingId], references: [id], onDelete: Cascade)
}

model Favorite {
  id        String   @id @default(cuid())
  userId    String
  listingId String
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  listing Listing @relation(fields: [listingId], references: [id], onDelete: Cascade)

  @@unique([userId, listingId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  createdAt DateTime @default(now())
  expiresAt DateTime

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}